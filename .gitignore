# .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / tooling
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime logs and receipts
logs/
receipts/
*.jsonl

# Runtime state that should not be versioned
state/external_memory/
AI_GO/logs/
AI_GO/state/

# Local environment files
.env
.env.local
.env.*.local