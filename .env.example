ENVIRONMENT=development
AI_GO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
AI_GO_API_KEY_HEADER=x-api-key

# Use either AI_GO_API_KEYS_JSON or AI_GO_API_KEY
AI_GO_API_KEYS_JSON={"default_operator":"replace-with-real-key"}
# AI_GO_API_KEY=replace-with-real-key

AI_GO_RATE_LIMIT_REQUESTS=60
AI_GO_RATE_LIMIT_WINDOW_SECONDS=60