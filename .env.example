# -----------------------------------------------------------------------------
# AI_GO — Local / Deployment Environment Example
# -----------------------------------------------------------------------------

# Environment label
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Trusted host hardening
# Comma-separated hostnames only. No protocol. No spaces needed.
#
# Local examples:
# AI_GO_ALLOWED_HOSTS=127.0.0.1,localhost
#
# Render example:
# AI_GO_ALLOWED_HOSTS=your-app-name.onrender.com
#
# Custom domain example:
# AI_GO_ALLOWED_HOSTS=your-app-name.onrender.com,app.yourdomain.com
# -----------------------------------------------------------------------------
AI_GO_ALLOWED_HOSTS=127.0.0.1,localhost

# -----------------------------------------------------------------------------
# API auth
#
# Preferred:
# JSON object of operator_name -> api_key
#
# Example:
# AI_GO_API_KEYS_JSON={"local_operator":"change-me-local","render_prod":"change-me-prod"}
#
# Legacy single-key fallback is still supported:
# AI_GO_API_KEY=change-me
# -----------------------------------------------------------------------------
AI_GO_API_KEYS_JSON={"local_operator":"change-me-local"}
AI_GO_API_KEY_HEADER=x-api-key

# Optional legacy fallback
# AI_GO_API_KEY=change-me-legacy

# -----------------------------------------------------------------------------
# Rate limiting
#
# Requests allowed per window per authenticated operator+route bucket.
# -----------------------------------------------------------------------------
AI_GO_RATE_LIMIT_REQUESTS=60
AI_GO_RATE_LIMIT_WINDOW_SECONDS=60